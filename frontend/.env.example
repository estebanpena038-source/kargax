# =============================================================================
# KargaX Environment Configuration
# =============================================================================
# Copy this file to .env.local for local development.
# Never commit real secrets. Rotate any value that was ever exposed in docs,
# chats, screenshots or commits.

# -----------------------------------------------------------------------------
# Public app configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=KargaX
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=es-CO
NEXT_PUBLIC_SUPPORTED_LOCALES=es-CO,en,pt-BR
NEXT_PUBLIC_DEFAULT_COUNTRY=CO
NEXT_PUBLIC_DEFAULT_CURRENCY=COP
NEXT_PUBLIC_PHONE_COUNTRY_CODE=+57
NEXT_PUBLIC_MARKET_COUNTRIES=CO,PE,EC

# Exact browser origins allowed to call /api/* cross-origin.
# Use a comma-separated list. Same-origin/server-to-server requests without
# an Origin header are still accepted.
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Mercado Pago
# -----------------------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=your-mercadopago-public-key
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# Development and preview only. Keep false unless you explicitly need
# unsigned webhook simulation outside production.
ALLOW_UNSIGNED_MP_WEBHOOKS_IN_PREVIEW=false

NEXT_PUBLIC_PLATFORM_FEE_PERCENT=8
NEXT_PUBLIC_PAYMENT_SUCCESS_URL=http://localhost:3000/pago/exitoso
NEXT_PUBLIC_PAYMENT_FAILURE_URL=http://localhost:3000/pago/fallido
NEXT_PUBLIC_PAYMENT_PENDING_URL=http://localhost:3000/pago/pendiente

# ---------------------------------------------------------------------------
# Founder-only CEO control tower
# ---------------------------------------------------------------------------
# Comma-separated allowlists. Keep empty in environments where nobody should
# open /admin/ceo. The user must also have user_type='admin'.
KARGAX_CEO_EMAILS=
KARGAX_CEO_USER_IDS=

# -----------------------------------------------------------------------------
# Internal server-to-server security
# -----------------------------------------------------------------------------
INTERNAL_API_KEY=replace-me-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# Valid values today: console, twilio
NOTIFICATION_PROVIDER=console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# -----------------------------------------------------------------------------
# Billing
# -----------------------------------------------------------------------------
BILLING_PLAN_CURRENCY_ID=COP
BILLING_PLAN_USD_TO_COP_RATE=4000

# -----------------------------------------------------------------------------
# Wallet payouts
# -----------------------------------------------------------------------------
# Keep payouts disabled/dry-run until production has signed webhooks,
# provider credentials, source account and low operational limits configured.
PAYOUTS_ENABLED=false
PAYOUT_DRY_RUN=true
PAYOUT_PROVIDER=manual
PAYOUT_WEBHOOK_SECRET=
PAYOUT_MAX_SINGLE_COP=500000
PAYOUT_DAILY_LIMIT_COP=2000000
PAYOUT_MIN_AMOUNT_COP=50000
PAYOUT_BATCH_SIZE=10
PRIVATE_FLEET_PAYROLL_WALLET_RELEASE_ENABLED=false

# Cobre adapter. Never commit real values.
COBRE_API_BASE_URL=
COBRE_API_KEY=
COBRE_SOURCE_ACCOUNT_ID=
COBRE_DEFAULT_BANK_CODE=

# -----------------------------------------------------------------------------
# Optional feature flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_REAL_TIME_TRACKING=true
NEXT_PUBLIC_ENABLE_DYNAMIC_PRICING=true
NEXT_PUBLIC_ENABLE_FLEET_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENTERPRISE_EXPERIENCE_MODE=true
NEXT_PUBLIC_ASYNC_NOTIFICATIONS=true
NEXT_PUBLIC_REPLAY_ACTIONS=true
NEXT_PUBLIC_DEGRADED_MODE_WALLET=false
NEXT_PUBLIC_DEGRADED_MODE_WAREHOUSE=false

# -----------------------------------------------------------------------------
# Observability and analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=
POSTHOG_CAPTURE_URL=

# -----------------------------------------------------------------------------
# Upstash Redis / QStash
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_URL=
QSTASH_TOKEN=
